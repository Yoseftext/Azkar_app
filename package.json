{
  "name": "azkar-app-next",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "npm run static:sync && node ./node_modules/typescript/bin/tsc --noEmit && node ./node_modules/vite/bin/vite.js build && node ./tools/finalize-dist.mjs",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "lint": "node ./tools/lint.mjs",
    "format": "node ./tools/format-check.mjs --write",
    "format:check": "node ./tools/format-check.mjs",
    "quran:split": "node ./tools/split-quran-data.mjs",
    "test": "node ./tools/run-tests.mjs",
    "test:run": "node ./tools/run-tests.mjs",
    "test:coverage": "node --experimental-test-coverage --import ./tools/test/register-alias-loader.mjs --test tests/**/*.test.ts",
    "duas:split": "node ./tools/split-duas-data.mjs",
    "stories:split": "node ./tools/split-stories-data.mjs",
    "content:split": "npm run quran:split && npm run azkar:split && npm run duas:split && npm run stories:split",
    "azkar:split": "node ./tools/split-azkar-data.mjs",
    "verify:browser": "node ./tools/verify-browser-runtime.mjs",
    "verify:e2e": "node ./tools/verify-real-browser-e2e.mjs",
    "verify:release": "node ./tools/run-release-gate.mjs",
    "static:sync": "node ./tools/static-shims.mjs",
    "static:check": "node ./tools/static-shims.mjs --check",
    "audit:chunks": "node ./tools/audit-chunks.mjs"
  },
  "dependencies": {
    "firebase": "12.11.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router-dom": "7.13.2",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.2.2",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "vite": "8.0.3"
  }
}
